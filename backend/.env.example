# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mydb

# Firebase Admin — path to your service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# GCP Storage
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=loque-brand
GCS_SERVICE_ACCOUNT_PATH=./gcs.json

# Google Gemini API (for image generation + LangChain agents)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# HeyGen — from app.heygen.com/home?nav=API
HEYGEN_API_KEY=your-heygen-api-key

# X (Twitter) OAuth 2.0 — from developer.x.com > your App > Keys & Tokens
# X_CONSUMER_KEY and X_SECRET_KEY are your OAuth 1.0a API Key/Secret (kept for
# reference / OAuth 1.0a use). For OAuth 2.0 PKCE, only Client ID + Secret are needed.
X_CONSUMER_KEY=your-x-consumer-key
X_SECRET_KEY=your-x-consumer-secret
X_BEARER_TOKEN=your-x-bearer-token
X_CLIENT_ID=your-x-oauth2-client-id
X_CLIENT_SECRET=your-x-oauth2-client-secret
# Must match exactly what's registered in the X Developer Portal callback URLs
X_CALLBACK_URL=http://localhost:3000/api/twitter/callback
